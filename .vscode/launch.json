{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Запуск сайта",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "3000"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "openExternally",
        "killOnServerStop": true,
        "pattern": "http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s/login.html"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Запуск с автоперезагрузкой (dev)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "server.js"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "3000"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "openExternally",
        "killOnServerStop": true,
        "pattern": "http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s/login.html"
      }
    }
  ]
}
